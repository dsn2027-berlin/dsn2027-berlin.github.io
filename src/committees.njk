---
layout: base.njk
title: DSN 2027 Organizing Committee
description: Current DSN 2027 organizing committee planning information.
permalink: /committees/
---

<section class="section page-title" aria-labelledby="page-title">
  <h1 id="page-title"><b>Organizing Committee</b></h1>
</section>

<section class="section committee-section" aria-label="Organizing Committee">
  <div class="committee-table-wrap">
    <table class="committee-table">
      <thead>
        <tr>
          <th class="committee-name-col">Name</th>
          <th>Institution</th>
          <th class="committee-country-col">Country</th>
        </tr>
      </thead>
      <tbody>
        {% for item in conference.roles %}
          <tr class="committee-role-row">
            <td colspan="3"><b>{{ item.role }}</b></td>
          </tr>
          {% if item.people.length %}
            {% for person in item.people %}
              {% set personName = person.name or person %}
              <tr>
                <td class="committee-name">
                  <div class="committee-person">
                    {% if person.photo %}
                      <img class="committee-photo" src="{{ person.photo }}" alt="{{ personName }}" width="80" height="80">
                    {% else %}
                      <div class="committee-avatar" aria-hidden="true">{{ personName | committeeInitials }}</div>
                    {% endif %}
                    {% if person.url %}
                      <a href="{{ person.url }}" target="_blank" rel="noopener">{{ personName }}</a>
                    {% else %}
                      <span>{{ personName }}</span>
                    {% endif %}
                  </div>
                </td>
                <td>{{ person.institution }}</td>
                <td>{{ person.country }}</td>
              </tr>
            {% endfor %}
          {% else %}
            <tr class="committee-pending-row">
              <td class="committee-name">
                <div class="committee-person">
                  <div class="committee-avatar committee-avatar-pending" aria-hidden="true">TBA</div>
                  <span>To be announced</span>
                </div>
              </td>
              <td></td>
              <td></td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
